{
  "manifest_version": 3,
  "name": "ネタメモ — コンテンツアイデア帳",
  "version": "1.0.0",
  "description": "右クリックでWebページをコンテンツアイデアとして保存。友達と共有・投票でベストネタを見つけよう！",
  "permissions": ["storage", "contextMenus", "activeTab", "sidePanel"],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "side_panel": {
    "default_path": "sidepanel/sidepanel.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
