{
  "manifest_version": 3,
  "name": "ピクセルホーム — 引っ越しタスクで部屋を作ろう",
  "version": "1.0.0",
  "description": "新しいタブにピクセルアートの部屋が表示されます。引っ越しタスクを完了して家具を増やそう！",
  "chrome_url_overrides": {
    "newtab": "src/newtab.html"
  },
  "permissions": ["storage"],
  "icons": {
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
