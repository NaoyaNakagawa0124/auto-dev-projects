{
  "manifest_version": 3,
  "name": "CivicSky",
  "version": "0.1.0",
  "description": "Your daily regulatory weather forecast — see the policy climate at a glance.",
  "chrome_url_overrides": {
    "newtab": "newtab.html"
  },
  "permissions": [
    "storage"
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
