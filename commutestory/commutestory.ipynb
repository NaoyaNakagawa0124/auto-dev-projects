  {"cell_type":"code","execution_count":null,"metadata":{},"outputs":[],"source":["import sys; sys.path.insert(0, 'src')\nimport plotly.graph_objects as go\nimport plotly.express as px\nimport pandas as pd\nfrom data_engine import *\nprint('✅ Ready. Your commute story begins...')"]},
  {"cell_type":"markdown","metadata":{},"source":["## 🗺️ The Route — Elevation Profile"]},
  {"cell_type":"code","execution_count":null,"metadata":{},"outputs":[],"source":["profile = get_elevation_profile()\npdf = pd.DataFrame(profile)\nfig = go.Figure()\nfig.add_trace(go.Scatter(x=pdf['distance_km'], y=pdf['elevation_m'], mode='lines+markers+text',\n    fill='tozeroy', fillcolor='rgba(100,92,231,0.15)', line=dict(color='#6b5ce7', width=3),\n    marker=dict(size=12, color=[{'tunnel':'#e94560','bridge':'#feca57','station':'#55efc4','brt':'#48dbfb','viaduct':'#ff6b6b'}.get(t,'#aaa') for t in pdf['type']]),\n    text=pdf['station'], textposition='top center', textfont=dict(size=9)))\nfig.add_hline(y=0, line_dash='dash', line_color='#555', annotation_text='Ground Level')\nfig.update_layout(title='🗺️ Commute Elevation Profile (19.8 km)', xaxis_title='Distance (km)',\n    yaxis_title='Elevation (m)', template='plotly_dark', height=400,\n    paper_bgcolor='#0a0a1a', plot_bgcolor='#12122a', font=dict(family='Georgia'))\nfig.show()"]},
  {"cell_type":"markdown","metadata":{},"source":["## 📖 The Chapters\n","*Read each station's story...*"]},
  {"cell_type":"code","execution_count":null,"metadata":{},"outputs":[],"source":["for s in STATIONS:\n    print(f\"\\n{'='*50}\")\n    print(f\"{s.icon} {s.chapter_title}\")\n    print(f\"Station: {s.name} | {s.distance_km} km | {s.engineering_type}\")\n    print(f\"{'='*50}\")\n    for line in s.narrative:\n        print(f\"  {line}\")\n    print(f\"\\n  💡 Fun fact: {s.fun_fact}\")"]},
  {"cell_type":"markdown","metadata":{},"source":["## 🌉 Harbor Bridge — Engineering Deep Dive"]},
  {"cell_type":"code","execution_count":null,"metadata":{},"outputs":[],"source":["bd = get_bridge_data()\ncats = list(bd.keys()); vals = list(bd.values())\nfig = go.Figure(go.Bar(x=[k.replace('_',' ').title() for k in cats], y=vals,\n    marker_color=['#6b5ce7','#e94560','#feca57','#55efc4','#48dbfb','#ff6b6b','#a29bfe','#fd79a8'],\n    text=vals, textposition='outside'))\nfig.update_layout(title='🌉 Harbor Bridge — Engineering Data', template='plotly_dark', height=400,\n    paper_bgcolor='#0a0a1a', plot_bgcolor='#12122a', font=dict(family='Georgia'))\nfig.show()"]},
  {"cell_type":"markdown","metadata":{},"source":["## 💰 BRT vs Rail — The Cost Revolution"]},
  {"cell_type":"code","execution_count":null,"metadata":{},"outputs":[],"source":["costs = get_cost_comparison()\nfig = go.Figure(go.Bar(x=['BRT (Built)', 'Rail (Equivalent)', 'Savings Redirected'],\n    y=[costs['brt_cost_million'], costs['rail_equivalent_million'], costs['savings_million']],\n    marker_color=['#55efc4', '#e94560', '#feca57'],\n    text=[f\"${v}M\" for v in [costs['brt_cost_million'], costs['rail_equivalent_million'], costs['savings_million']]],\n    textposition='outside'))\nfig.update_layout(title='💰 BRT vs Rail Cost Comparison ($M)', yaxis_title='Cost ($M)',\n    template='plotly_dark', height=350, paper_bgcolor='#0a0a1a', plot_bgcolor='#12122a', font=dict(family='Georgia'))\nfig.show()\nprint(f\"BRT saved ${costs['savings_million']}M — redirected to bike lanes and parks.\")"]},
  {"cell_type":"markdown","metadata":{},"source":["## 👥 Daily Passengers by Station"]},
  {"cell_type":"code","execution_count":null,"metadata":{},"outputs":[],"source":["pax = get_passenger_data()\npdf = pd.DataFrame(pax)\nfig = go.Figure(go.Bar(x=[f\"{r['icon']} {r['station']}\" for _,r in pdf.iterrows()], y=pdf['passengers'],\n    marker_color='#6b5ce7', text=[f\"{p:,}\" for p in pdf['passengers']], textposition='outside'))\nfig.update_layout(title='👥 Daily Passengers by Station', yaxis_title='Passengers',\n    template='plotly_dark', height=350, paper_bgcolor='#0a0a1a', plot_bgcolor='#12122a', font=dict(family='Georgia'))\nfig.show()"]},
  {"cell_type":"markdown","metadata":{},"source":["## 🌱 Sustainability Metrics"]},
  {"cell_type":"code","execution_count":null,"metadata":{},"outputs":[],"source":["sus = get_sustainability_data()\nsdf = pd.DataFrame(sus)\nfig = px.bar(sdf, x='station', y='value', color='metric', barmode='group',\n    color_discrete_sequence=['#55efc4','#6b5ce7','#feca57','#48dbfb','#e94560'])\nfig.update_layout(title='🌱 Station Sustainability Metrics', template='plotly_dark', height=400,\n    paper_bgcolor='#0a0a1a', plot_bgcolor='#12122a', font=dict(family='Georgia'))\nfig.show()"]},
  {"cell_type":"markdown","metadata":{},"source":["## 🏗️ Construction Timeline"]},
  {"cell_type":"code","execution_count":null,"metadata":{},"outputs":[],"source":["tl = get_construction_timeline()\ntdf = pd.DataFrame(tl)\nfig = go.Figure(go.Scatter(x=tdf['year'], y=range(len(tdf)), mode='markers+text',\n    marker=dict(size=20, color='#feca57'), text=[f\"{r['icon']} {r['station']}\" for _,r in tdf.iterrows()],\n    textposition='middle right', textfont=dict(size=11)))\nfig.update_layout(title='🏗️ When Each Station Was Built', xaxis_title='Year',\n    yaxis=dict(visible=False), template='plotly_dark', height=350,\n    paper_bgcolor='#0a0a1a', plot_bgcolor='#12122a', font=dict(family='Georgia'))\nfig.show()"]},
