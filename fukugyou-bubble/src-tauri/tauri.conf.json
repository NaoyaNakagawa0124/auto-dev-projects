{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "副業バブル",
  "version": "0.1.0",
  "identifier": "com.autodev.fukugyoububble",
  "build": {
    "frontendDist": "../src",
    "devUrl": "http://localhost:8000"
  },
  "app": {
    "windows": [
      {
        "title": "副業バブル",
        "width": 1100,
        "height": 760,
        "minWidth": 720,
        "minHeight": 560,
        "resizable": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; script-src 'self'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.png"]
  }
}
