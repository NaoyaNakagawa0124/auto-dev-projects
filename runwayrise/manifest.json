{
  "manifest_version": 3,
  "name": "RunwayRise - Fashion Fitness RPG",
  "version": "1.0.0",
  "description": "Your workouts fuel your rise from fashion intern to creative director. An RPG where fitness = style.",
  "permissions": ["storage"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "images/icon16.png",
      "48": "images/icon48.png",
      "128": "images/icon128.png"
    }
  },
  "icons": {
    "16": "images/icon16.png",
    "48": "images/icon48.png",
    "128": "images/icon128.png"
  }
}
